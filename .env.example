# ─────────────────────────────────────────────────────────────────────────────
# BookMint AI — Environment Variables
# Copy this file to .env.local (for local dev) or set these in your host panel.
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI API Key — required for image generation
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Node environment
NODE_ENV=production

# ─── Future / optional ────────────────────────────────────────────────────────

# Stripe (for payments — not yet implemented)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# NextAuth (for authentication — not yet implemented)
# NEXTAUTH_SECRET=your-secret-here
# NEXTAUTH_URL=https://bookmintai.ca

# Database (for history & usage limits — not yet implemented)
# DATABASE_URL=postgres://user:password@host:5432/bookmintai
